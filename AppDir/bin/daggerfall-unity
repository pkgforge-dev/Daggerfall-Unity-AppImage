#!/bin/sh
export SHARUN_DIR=$APPDIR

_save_dir=${XDG_DATA_HOME:-~/.local/share}/daggerfall-unity/save
_config_source="/usr/share/daggerfall-unity/settings-template.ini"
_config_file=${XDG_CONFIG_HOME:-~/.config}/unity3d/'Daggerfall Workshop'/'Daggerfall Unity'/settings.ini

mkdir -p "${_config_file%/*}" "$_save_dir"
if [ ! -f "$_config_file" ]; then
    cp "$_config_source" "$_config_file"
    sed -i "s|MyDaggerfallUnitySavePath = |MyDaggerfallUnitySavePath = $_save_dir|g" "$_config_file"
fi

exec "$APPDIR"/bin/engine/DaggerfallUnity.x86_64 "$@"
